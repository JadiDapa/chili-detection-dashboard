model Captures {
    id        Int     @id @default(autoincrement())
    title     String?
    sessionId Int
    session   Session @relation(fields: [sessionId], references: [id])
    plantId   Int?
    plant     Plant?  @relation(fields: [plantId], references: [id])

    plantIndex Int?
    row        Int?
    col        Int?

    imageUrl   String
    imageLocal Boolean @default(true) // false = still pointing at RPi URL

    // YOLO-annotated frame (boxes drawn). Null when YOLO ran in stub mode or
    // rendering failed — the UI falls back to imageUrl. annotatedImageLocal
    // mirrors imageLocal: false = still pointing at the RPi static URL.
    annotatedImageUrl   String?
    annotatedImageLocal Boolean @default(true)

    totalFruits  Int @default(0)
    ripeCount    Int @default(0)
    turningCount Int @default(0)
    unripeCount  Int @default(0)
    brokenCount  Int @default(0)

    heightCm       Float?
    moisturePct    Float?

    valveDurationSec Float?
    wateringReason   String?

    scannedAt  DateTime  @default(now())
    lateSynced Boolean   @default(false)
    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt
}
