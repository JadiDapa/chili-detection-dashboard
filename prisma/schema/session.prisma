enum SessionStatus {
    PENDING // created in dashboard, not started yet
    RUNNING // Pi is actively scanning
    COMPLETED // all plants scanned, summary saved
    STOPPED // manually stopped before completion
    ERROR // something went wrong on the Pi
}

enum SessionType {
    SCAN
    WATERING
    DATA_COLLECTION
}

model Session {
    id         Int     @id @default(autoincrement())
    title      String?
    notes      String?
    externalId String? @unique // RPi's own session_id

    bedId Int
    bed   Bed @relation(fields: [bedId], references: [id])

    startedAt   DateTime?
    completedAt DateTime?
    status      SessionStatus @default(PENDING)
    sessionType SessionType   @default(SCAN)

    // SCAN summary — written when session_complete fires
    totalPlants     Int?
    avgHeightCm     Float?
    avgMoisturePct  Float?
    totalWaterSec   Float?
    harvestReadyIds String? // JSON array e.g. "[3,7,12]"

    // Ripeness totals across all plants (convenience denormalization)
    totalRipe    Int?
    totalTurning Int?
    totalUnripe  Int?
    totalDamaged Int?

    // Scan configuration — which preset was used and a frozen copy at session-start time
    scanConfigId       Int?
    scanConfig         ScanConfig? @relation(fields: [scanConfigId], references: [id])
    scanConfigSnapshot Json?

    // WATERING-only summary fields
    maxHeightCm       Float? // global max plant height from TOF sweep
    fuzzyDurationSec  Float? // fuzzy logic output watering duration
    stopsWatered      Int?   // number of column stops completed
    moistureBeforeAvg Float? // avg of 3 soil sensors before watering
    moistureAfterAvg  Float? // avg of 3 soil sensors after watering

    // Watering configuration — preset used and frozen copy
    wateringConfigId       Int?
    wateringConfig         WateringConfig? @relation(fields: [wateringConfigId], references: [id])
    wateringConfigSnapshot Json?

    // DATA_COLLECTION-only — recorded sweep video + the config used
    videoUrl              String? // dashboard-hosted /api/uploads/<name>.mp4
    videoDurationSec      Float?
    datasetConfigId       Int?
    datasetConfig         DatasetConfig? @relation(fields: [datasetConfigId], references: [id])
    datasetConfigSnapshot Json?

    // Relations
    captures      Captures[]
    wateringStops WateringStop[]
    scheduleRun   ScheduleRun? // set when this session was created by a scheduled task

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([bedId])
    @@index([status])
    @@index([sessionType])
    @@index([createdAt])
}
