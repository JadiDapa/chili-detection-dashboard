model ScanConfig {
    id          Int     @id @default(autoincrement())
    name        String
    description String?
    isDefault   Boolean @default(false)

    cols Int   @default(8)
    rows Int   @default(2)

    gapXMm  Float @default(750.0)
    gapYMm  Float @default(1000.0)
    startXMm Float @default(0.0)
    startYMm Float @default(0.0)

    // Array of CaptureOffset: [{z_mm, x_offset_mm, y_offset_mm, servo_pan, servo_tilt}]
    captureOffsets Json

    sessions Session[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([isDefault])
}
