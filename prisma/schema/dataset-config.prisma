model DatasetConfig {
    id          Int     @id @default(autoincrement())
    name        String
    description String?
    isDefault   Boolean @default(false)

    cols Int @default(8)
    rows Int @default(2)

    gapXMm   Float @default(750.0)
    gapYMm   Float @default(1000.0)
    startXMm Float @default(0.0)
    startYMm Float @default(0.0)

    zMm        Float @default(50.0)  // Z height held constant during the sweep
    speedMmSec Float @default(100.0) // gantry travel speed during the continuous pass

    sessions Session[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([isDefault])
}
