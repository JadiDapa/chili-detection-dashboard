model DatasetConfig {
    id          Int     @id @default(autoincrement())
    name        String
    description String?
    isDefault   Boolean @default(false)

    zMm        Float @default(50.0)  // Z height held constant during the sweep
    speedMmSec Float @default(100.0) // gantry travel speed during the continuous pass

    sessions Session[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([isDefault])
}
